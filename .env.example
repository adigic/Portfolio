# Canonical site URL, used for metadata/OpenGraph and the generated sitemap.
# Defaults to https://adigic.se if unset.
NEXT_PUBLIC_SITE_URL=https://adigic.se

# Sanity project — https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API token with read (and, for scripts/migrate-projects.js, write) access.
# Only needed server-side / for one-off scripts — never expose this publicly.
SANITY_API_TOKEN=

# Resend – https://resend.com/api-keys
RESEND_API_KEY=

# Sender address. Must be on a domain verified in Resend
# (shared sender domain, same as in rsiteknik).
RESEND_FROM="Adis Hegic <formular@contact.adigic.se>"

# Inbox the contact form messages are sent to.
RESEND_TO=adigic@hotmail.com

# Google Analytics 4 – only loaded after cookie consent.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
